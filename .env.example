# FitCore Environment Variables

# JWT Secret (change in production!)
JWT_SECRET=fitcore-secret-change-me-in-production

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: USDA FoodData Central API Key (for production)
# Get yours at: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# Server Port
PORT=4000
